FROM python:3.13-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app

RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir fastapi uvicorn sqlalchemy asyncpg psycopg2-binary alembic pydantic pydantic-settings httpx apscheduler python-dotenv structlog orjson

COPY . .

CMD ["python", "-m", "app.jobs.runner"]
