# App
APP_ENV=local
LOG_LEVEL=DEBUG

# Database (Railway provides DATABASE_URL automatically via PostgreSQL plugin)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rupiahpulse

# CORS - comma-separated origins for staging/production
CORS_ORIGINS=http://localhost:5173

# Data Provider timeout in seconds
DATA_PROVIDER_TIMEOUT_SECONDS=15

# GDELT news query
GDELT_QUERY=indonesia rupiah

# Cache TTL
CACHE_TTL_SECONDS_EXPLANATION=300
CACHE_TTL_SECONDS_NEWS=600
